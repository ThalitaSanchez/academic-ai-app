# Database
DATABASE_URL="postgresql://user:password@localhost:5432/academic_ai_db"
DATABASE_SHADOW_URL="postgresql://user:password@localhost:5432/academic_ai_db_shadow"

# Redis
REDIS_URL="redis://localhost:6379"

# OpenAI
OPENAI_API_KEY="sk-your-key-here"
OPENAI_ORG_ID="org-your-id"

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# API
API_PORT=4000
API_HOST=0.0.0.0
NEXT_PUBLIC_API_URL="http://localhost:4000"

# Frontend
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Academic AI App"

# Email (Resend ou SendGrid)
RESEND_API_KEY="re_your-key"

# Storage (AWS S3 ou Supabase)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-key"
AWS_SECRET_ACCESS_KEY="your-secret"
AWS_S3_BUCKET="academic-ai-storage"

# Google OAuth (opcional)
NEXT_PUBLIC_GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-secret"

# GitHub OAuth (opcional)
NEXT_PUBLIC_GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-secret"

# Pinecone (Vector DB)
PINECONE_API_KEY="your-pinecone-key"
PINECONE_ENVIRONMENT="production"
PINECONE_INDEX_NAME="academic-ai"

# Environment
NODE_ENV="development"
NEXT_PUBLIC_ENV="development"

# Logging
LOG_LEVEL="debug"
SENTRY_DSN=""

# Analytics
NEXT_PUBLIC_GA_ID=""