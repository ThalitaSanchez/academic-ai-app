# ========================================
# FRONTEND (Next.js)
# ========================================

# API
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_NAME=Academic AI

# Supabase (Authentication & Realtime DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OpenAI (for API calls from frontend)
NEXT_PUBLIC_OPENAI_API_KEY=sk_test_...

# ========================================
# BACKEND (Express)
# ========================================

# Node Environment
NODE_ENV=development

# Database
DATABASE_URL=postgresql://academic_user:academic_password@localhost:5432/academic_ai_db

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI API
OPENAI_API_KEY=sk_test_...

# Supabase Service Role (backend only!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRATION=7d

# API
API_PORT=4000
API_HOST=0.0.0.0

# CORS
CORS_ORIGIN=http://localhost:3000

# ========================================
# AI & ML
# ========================================

# LangChain
LANGCHAIN_API_KEY=sk_test_...

# Pinecone (Vector DB)
PINCONE_API_KEY=your_key
PINCONE_ENVIRONMENT=gcp-starter

# ========================================
# SECURITY
# ========================================

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ========================================
# MONITORING & LOGGING
# ========================================

# Sentry
SENTRY_DSN=https://your_sentry_dsn

# DataDog
DATADOG_API_KEY=your_datadog_key

# ========================================
# DEVELOPMENT
# ========================================

# Debug
DEBUG=true
LOG_LEVEL=debug

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password